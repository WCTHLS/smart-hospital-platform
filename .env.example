# ---- Backend ----
ENVIRONMENT=development
# Zero-setup dev uses SQLite. For Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg://aarogya:aarogya@localhost:5432/aarogya
DATABASE_URL=sqlite:///./smart_hospital.db

# ---- AI / Ollama (optional; app falls back to deterministic engine if unavailable) ----
AI_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---- Security ----
JWT_SECRET=dev-secret-change-me

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000
